# ─────────────────────────────────────────────────────────────────────────────
# Research Agent — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to git (it's already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Choose: "ollama" (local, free, needs Ollama installed)
#      or "huggingface" (free cloud API, needs HF token below)
# Default to HuggingFace for hosted deployments (Streamlit Cloud often has no
# local Ollama server/model). For local runs, switch this to "ollama".
LLM_BACKEND=huggingface

# ── Ollama settings (only needed if LLM_BACKEND=ollama) ──────────────────────
# Install Ollama: https://ollama.com/download
# Then run:       ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Other free models: mistral, phi3, gemma, codellama

# ── HuggingFace settings (only needed if LLM_BACKEND=huggingface) ────────────
# Get a FREE token at: https://huggingface.co/settings/tokens
# No credit card required.
HF_API_TOKEN=
HF_MODEL_REPO=mistralai/Mistral-7B-Instruct-v0.3
# Other free models: google/flan-t5-xxl, HuggingFaceH4/zephyr-7b-beta

# ── Embeddings ────────────────────────────────────────────────────────────────
# For Streamlit Cloud (hosted), we default to TF-IDF to avoid heavy
# torch/sentence-transformers installs. For local/offline high quality,
# set to `sentence-transformers`.
EMBEDDINGS_BACKEND=tfidf
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Heavier but more accurate: sentence-transformers/all-mpnet-base-v2
