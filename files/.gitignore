# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Research Agent
# ─────────────────────────────────────────────────────────────────────────────

# Secrets — NEVER commit these
.env
*.pem
*.key
secrets/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
.venv/
venv/
env/
ENV/

# Testing & Coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# HuggingFace / model cache (large files — use Docker volume instead)
.cache/
*.cache/
models/

# FAISS index files (regenerated at runtime)
*.index
*.faiss

# Streamlit
.streamlit/secrets.toml

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
*.log
